# Provedor padrão: openai | ollama
AI_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-proj-...
AI_MODEL=gpt-4o-mini

# Ollama (local, opcional)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

AI_SERVICE_PORT=8002

# Segurança: token interno PHP → Python (gere um UUID aleatório)
AI_INTERNAL_TOKEN=troque-por-um-token-secreto-aqui
