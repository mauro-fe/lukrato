{
  "name": "seu-projeto/lukrato",
  "description": "Sistema de gestão financeira pessoal",
  "type": "project",
  "require": {
    "php": "^8.0",
    "cocur/slugify": "4.6.0",
    "dompdf/dompdf": "^3.1",
    "google/apiclient": "2.18",
    "guzzlehttp/guzzle": "^7.10",
    "illuminate/database": "^11.0",
    "illuminate/events": "^11.0",
    "laravel/serializable-closure": "^2.0",
    "mercadopago/dx-php": "3.6.0",
    "monolog/monolog": "^3.9",
    "nesbot/carbon": "^3.10.1",
    "phpmailer/phpmailer": "^6.9",
    "phpoffice/phpspreadsheet": "^5.3",
    "predis/predis": "^1.1",
    "tecnickcom/tcpdf": "*",
    "vlucas/phpdotenv": "*",
    "wixel/gump": "^2.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0 || ^11.0",
    "mockery/mockery": "^1.6"
  },
  "autoload": {
    "psr-4": {
      "Application\\": "Application/",
      "App\\": "Application/"
    },
    "files": [
      "Application/Lib/Helpers_global.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "test:core-router": "@php vendor/bin/phpunit tests/Unit/Core/RouterTest.php tests/Unit/Core/MiddlewareResolverTest.php tests/Unit/Core/RequestTest.php tests/Unit/Core/ResponseTest.php",
    "test:architecture": "@php vendor/bin/phpunit tests/Unit/Controllers/ControllerLayeringTest.php tests/Unit/Controllers/ApiControllerTest.php tests/Unit/Controllers/WebControllerTest.php",
    "test:routes": "@php vendor/bin/phpunit tests/Unit/Core/RouteIntegrityTest.php",
    "test:backend": [
      "@composer test:routes",
      "@composer test:core-router",
      "@composer test:architecture"
    ],
    "install-pdf": [
      "composer require tecnickcom/tcpdf",
      "composer require dompdf/dompdf"
    ]
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true
  }
  
}
