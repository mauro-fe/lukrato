{
  "name": "seu-projeto/lukrato",
  "description": "Sistema de gestão financeira pessoal",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": "^8.2",
    "cocur/slugify": "^4.6",
    "dompdf/dompdf": "^3.1",
    "google/apiclient": "^2.18",
    "guzzlehttp/guzzle": "^7.10",
    "illuminate/database": "^11.0",
    "illuminate/events": "^11.0",
    "laravel/serializable-closure": "^2.0",
    "mercadopago/dx-php": "^3.6",
    "monolog/monolog": "^3.9",
    "nesbot/carbon": "^3.10.1",
    "phpmailer/phpmailer": "^6.9",
    "phpoffice/phpspreadsheet": "^5.3",
    "predis/predis": "^1.1",
    "tecnickcom/tcpdf": "^6.11",
    "vlucas/phpdotenv": "^5.6",
    "wixel/gump": "^2.2"
  },
  "require-dev": {
    "larastan/larastan": "^3.9",
    "mockery/mockery": "^1.6",
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^10.0 || ^11.0"
  },
  "autoload": {
    "psr-4": {
      "Application\\": "Application/",
      "App\\": "Application/"
    },
    "files": [
      "Application/Lib/Helpers_global.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "test:core-router": "@php vendor/bin/phpunit tests/Unit/Core/RouterTest.php tests/Unit/Core/MiddlewareResolverTest.php tests/Unit/Core/RequestTest.php tests/Unit/Core/ResponseTest.php",
    "test:architecture": "@php vendor/bin/phpunit tests/Unit/Controllers/ControllerLayeringTest.php tests/Unit/Controllers/ControllerDependencyCompositionGuardTest.php tests/Unit/Controllers/ApiControllerTest.php tests/Unit/Controllers/WebControllerTest.php tests/Unit/UseCases/UseCaseDependencyCompositionGuardTest.php tests/Unit/Architecture/ManualCompositionAllowlistTest.php",
    "test:routes": "@php vendor/bin/phpunit tests/Unit/Core/RouteIntegrityTest.php",
    "test:backend": [
      "@composer test:routes",
      "@composer test:core-router",
      "@composer test:architecture"
    ],
    "test:backend:full": "@php vendor/bin/phpunit",
    "analyse": "@php vendor/bin/phpstan analyse --memory-limit=1G",
    "guard:backend": [
      "@composer validate --strict",
      "@composer analyse",
      "@composer test:backend:full"
    ],
    "guard:all": [
      "@composer guard:backend",
      "npm run guard:front",
      "npm run check:encoding"
    ],
    "install-pdf": [
      "composer require tecnickcom/tcpdf",
      "composer require dompdf/dompdf"
    ]
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true
  }
  
}
