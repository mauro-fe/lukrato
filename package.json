{
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build --config vite.config.producao.js",
    "build:local": "vite build",
    "preview": "vite preview",
    "lint:js": "node scripts/ensure-vite-check-dir.mjs && eslint \"resources/js/**/*.js\" --cache --cache-location \"storage/vite-check/.eslintcache\"",
    "lint:js:fix": "node scripts/ensure-vite-check-dir.mjs && eslint \"resources/js/**/*.js\" --cache --cache-location \"storage/vite-check/.eslintcache\" --fix",
    "check:js-size": "node scripts/check-js-size.mjs",
    "check:js-size:all": "node scripts/check-js-size.mjs --all",
    "test:js": "vitest run --passWithNoTests",
    "guard:front": "npm run lint:js && npm run check:js-size && npm run build:local",
    "check:encoding": "node scripts/check-encoding.mjs",
    "check:encoding:staged": "node scripts/check-encoding.mjs --staged",
    "setup:githooks": "node scripts/setup-githooks.mjs",
    "prepare": "node scripts/setup-githooks.mjs"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "eslint": "^10.1.0",
    "jsdom": "^29.0.2",
    "localtunnel": "^2.0.2",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "terser": "^5.46.0",
    "vite": "^7.3.1",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "driver.js": "^1.4.0"
  }
}
